# .env.example — safe to commit, contains no real values
# Copy this file to .env.local and fill in your values for local development.
# For production, set these in Vercel → Project → Settings → Environment Variables.

# Public API base URL (exposed to the browser via NEXT_PUBLIC_)
# Local dev:   /api   (proxied by Next.js rewrites to INTERNAL_API_URL)
# Production:  full Azure / backend URL
NEXT_PUBLIC_API_BASE_URL=

# Internal server-to-server API URL (never sent to the browser)
# Used by: app/api/auth/login, app/api/auth/register, app/api/products/*
# Local dev:   http://localhost:5181/api
# Production:  full Azure / backend URL
INTERNAL_API_URL=
